{
  "openapi": "3.0.3",
  "info": {
    "title": "JSONPlaceholder API",
    "description": "Free fake REST API for testing and prototyping — real live server at jsonplaceholder.typicode.com",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "https://jsonplaceholder.typicode.com" }
  ],
  "paths": {
    "/posts": {
      "get": { "summary": "Get all posts", "responses": { "200": { "description": "List of posts" } } },
      "post": { "summary": "Create a post", "responses": { "201": { "description": "Created" } } }
    },
    "/posts/{id}": {
      "get": {
        "summary": "Get post by ID",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Post" } }
      },
      "put": {
        "summary": "Update a post",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "summary": "Delete a post",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/posts/{id}/comments": {
      "get": {
        "summary": "Get comments for a post",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Comments" } }
      }
    },
    "/users": {
      "get": { "summary": "Get all users", "responses": { "200": { "description": "List of users" } } }
    },
    "/users/{id}": {
      "get": {
        "summary": "Get user by ID",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "User" } }
      }
    },
    "/todos": {
      "get": { "summary": "Get all todos", "responses": { "200": { "description": "List of todos" } } }
    },
    "/albums": {
      "get": { "summary": "Get all albums", "responses": { "200": { "description": "List of albums" } } }
    }
  }
}
