# ============ Environment ============
GATEWAY_ENV=dev

# ============ Database ============
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gateway
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ============ RabbitMQ ============
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/cem

# ============ SMTP (dev: use MailHog) ============
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_TLS=false

# ============ Identity / JWT ============
JWT_ISSUER_URI=http://localhost:8081
JWT_KEYSTORE_PASSWORD=changeit
JWT_KEY_ALIAS=gateway-jwt

# ============ Service URLs (Docker internal) ============
IDENTITY_SERVICE_URL=http://identity-service:8081
MANAGEMENT_API_URL=http://management-api:8082
GATEWAY_RUNTIME_URL=http://gateway-runtime:8080

# ============ Frontend ============
NEXT_PUBLIC_API_URL=http://localhost:8082
NEXT_PUBLIC_IDENTITY_URL=http://localhost:8081
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
