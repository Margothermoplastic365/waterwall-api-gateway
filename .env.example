# =============================================================================
# API Gateway Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines marked [REQUIRED] must be set for production.
# Lines marked [OPTIONAL] have sensible defaults and can be left as-is.
# NEVER commit the .env file with real credentials to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. General
# -----------------------------------------------------------------------------

# [OPTIONAL] Active Spring profile: dev | staging | prod
GATEWAY_ENV=dev


# -----------------------------------------------------------------------------
# 2. Database (PostgreSQL) - used by ALL 5 Spring Boot services
# -----------------------------------------------------------------------------

# [REQUIRED] Database host
DB_HOST=localhost

# [OPTIONAL] Database port
DB_PORT=5432

# [OPTIONAL] Database name
DB_NAME=gateway

# [REQUIRED] Database credentials
DB_USERNAME=postgres
DB_PASSWORD=change-me

# [OPTIONAL] Connection pool size (gateway-runtime only)
DB_POOL_SIZE=30


# -----------------------------------------------------------------------------
# 3. RabbitMQ - used by ALL 5 Spring Boot services
# -----------------------------------------------------------------------------

# [REQUIRED] RabbitMQ host
RABBITMQ_HOST=localhost

# [OPTIONAL] RabbitMQ AMQP port
RABBITMQ_PORT=5672

# [OPTIONAL] RabbitMQ management UI port (Docker only)
RABBITMQ_MGMT_PORT=15672

# [REQUIRED] RabbitMQ credentials
RABBITMQ_USERNAME=change-me
RABBITMQ_PASSWORD=change-me

# [OPTIONAL] RabbitMQ virtual host
RABBITMQ_VHOST=/cem


# -----------------------------------------------------------------------------
# 4. SMTP / Mail - used by identity-service, analytics-service, notification-service
# -----------------------------------------------------------------------------

# [REQUIRED] SMTP server host
MAIL_HOST=smtp-relay.brevo.com

# [OPTIONAL] SMTP server port
MAIL_PORT=587

# [REQUIRED] SMTP credentials
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password

# [OPTIONAL] SMTP settings
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# [OPTIONAL] Sender address shown in outgoing emails
MAIL_FROM=noreply@example.com


# -----------------------------------------------------------------------------
# 5. JWT / Auth - used by identity-service
# -----------------------------------------------------------------------------

# [OPTIONAL] JWT issuer URI (typically the identity-service base URL)
JWT_ISSUER_URI=http://localhost:8081

# [OPTIONAL] Path to the JKS keystore containing the JWT signing key
JWT_KEYSTORE_PATH=classpath:keys/gateway-jwt.jks

# [REQUIRED] Password for the JWT keystore
JWT_KEYSTORE_PASSWORD=changeit

# [OPTIONAL] Alias of the signing key inside the keystore
JWT_KEY_ALIAS=gateway-jwt


# -----------------------------------------------------------------------------
# 6. OAuth2 - used by identity-service
# -----------------------------------------------------------------------------

# [OPTIONAL] Default OAuth2 client ID
OAUTH2_CLIENT_ID=gateway-portal

# [REQUIRED] OAuth2 client secret
OAUTH2_CLIENT_SECRET=change-me

# [OPTIONAL] OAuth2 redirect URI after authentication
OAUTH2_REDIRECT_URI=http://localhost:3000/api/auth/callback

# [OPTIONAL] Token TTLs
OAUTH2_ACCESS_TOKEN_TTL_HOURS=1
OAUTH2_REFRESH_TOKEN_TTL_DAYS=30


# -----------------------------------------------------------------------------
# 7. Social Login (OAuth2 Providers) - used by identity-service
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable social login
SOCIAL_LOGIN_ENABLED=false

# [OPTIONAL] Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [OPTIONAL] GitHub OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# [OPTIONAL] Azure AD / Microsoft OAuth2
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common


# -----------------------------------------------------------------------------
# 8. Paystack (Payment Gateway) - used by management-api
# -----------------------------------------------------------------------------

# [REQUIRED for billing] Paystack API keys
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# [OPTIONAL] Paystack payment callback URL
PAYSTACK_CALLBACK_URL=http://localhost:3000/billing?verify=true


# -----------------------------------------------------------------------------
# 9. Service URLs - used for inter-service communication
# -----------------------------------------------------------------------------

# [REQUIRED] Identity service base URL (used by management-api, analytics, notification, gateway-runtime)
IDENTITY_SERVICE_URL=http://localhost:8081

# [OPTIONAL] Management API base URL (used by Docker / frontend)
MANAGEMENT_API_URL=http://localhost:8082

# [OPTIONAL] Gateway runtime base URL
GATEWAY_RUNTIME_URL=http://localhost:8080

# [OPTIONAL] Gateway runtime HTTP port
GATEWAY_HTTP_PORT=8080


# -----------------------------------------------------------------------------
# 10. Frontend (Next.js) - used by gateway-portal and gateway-admin
# -----------------------------------------------------------------------------

# [REQUIRED] Management API URL exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8082

# [REQUIRED] Identity service URL exposed to the browser
NEXT_PUBLIC_IDENTITY_URL=http://localhost:8081

# [REQUIRED] Gateway runtime URL exposed to the browser
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# [OPTIONAL] Analytics service URL exposed to the browser
NEXT_PUBLIC_ANALYTICS_URL=http://localhost:8083

# [OPTIONAL] Notification service URL exposed to the browser
NEXT_PUBLIC_NOTIFICATION_URL=http://localhost:8084

# [OPTIONAL] Management API URL (alias used on some admin pages)
NEXT_PUBLIC_MANAGEMENT_URL=http://localhost:8082

# [OPTIONAL] Portal URL (used by admin sidebar link back to portal)
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# 11. CORS - used by identity-service and gateway-runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# [OPTIONAL] Comma-separated list of allowed HTTP methods
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS,HEAD

# [OPTIONAL] Comma-separated list of allowed headers
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key,X-Trace-Id

# [OPTIONAL] Whether to allow credentials (cookies, auth headers)
CORS_ALLOW_CREDENTIALS=true

# [OPTIONAL] CORS preflight cache max age in seconds (gateway-runtime only)
CORS_MAX_AGE=3600


# -----------------------------------------------------------------------------
# 12. API Key Settings - used by identity-service and gateway-runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] Prefix for generated API keys
APIKEY_PREFIX=live

# [OPTIONAL] Grace period (hours) after key rotation before old key is revoked
APIKEY_ROTATION_GRACE_HOURS=168


# -----------------------------------------------------------------------------
# 13. Gateway Runtime - Proxy Settings
# -----------------------------------------------------------------------------

# [OPTIONAL] Proxy connection timeout in milliseconds
PROXY_CONNECT_TIMEOUT=10000

# [OPTIONAL] Proxy read timeout in milliseconds
PROXY_READ_TIMEOUT=60000

# [OPTIONAL] Maximum concurrent proxy connections
PROXY_MAX_CONNECTIONS=200

# [OPTIONAL] Maximum request body size in bytes (default 10MB)
PROXY_MAX_BODY_SIZE=10485760


# -----------------------------------------------------------------------------
# 14. Gateway Runtime - Load Balancing & Circuit Breaker
# -----------------------------------------------------------------------------

# [OPTIONAL] Load balancing algorithm: round-robin | least-connections | random
LB_ALGORITHM=round-robin

# [OPTIONAL] Health check interval in milliseconds
LB_HEALTH_CHECK_INTERVAL=30000

# [OPTIONAL] Circuit breaker failure threshold before opening
LB_CB_FAILURE_THRESHOLD=5

# [OPTIONAL] Circuit breaker reset timeout in seconds
LB_CB_RESET_TIMEOUT=60

# [OPTIONAL] Maximum retry attempts
LB_RETRY_MAX=2

# [OPTIONAL] Retry backoff in milliseconds
LB_RETRY_BACKOFF=100


# -----------------------------------------------------------------------------
# 15. Gateway Runtime - Rate Limiting
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable rate limit sync across instances
RATELIMIT_SYNC_ENABLED=true

# [OPTIONAL] Default rate limits
RATELIMIT_DEFAULT_RPS=100
RATELIMIT_DEFAULT_RPM=1000
RATELIMIT_DEFAULT_RPD=100000
RATELIMIT_DEFAULT_BURST=10
RATELIMIT_STRICT_WINDOW=60


# -----------------------------------------------------------------------------
# 16. Gateway Runtime - Security Headers & IP Filtering
# -----------------------------------------------------------------------------

# [OPTIONAL] HSTS max-age in seconds
SECURITY_HSTS_MAX_AGE=31536000

# [OPTIONAL] X-Frame-Options value
SECURITY_FRAME_OPTIONS=DENY

# [OPTIONAL] Content-Security-Policy header value
SECURITY_CSP=default-src 'self'

# [OPTIONAL] Referrer-Policy header value
SECURITY_REFERRER=strict-origin-when-cross-origin

# [OPTIONAL] Permissions-Policy header value
SECURITY_PERMISSIONS_POLICY=

# [OPTIONAL] Comma-separated IP whitelist (empty = allow all)
SECURITY_IP_WHITELIST=

# [OPTIONAL] Comma-separated IP blacklist
SECURITY_IP_BLACKLIST=

# [OPTIONAL] Trust X-Forwarded-For header (set true behind a reverse proxy)
SECURITY_TRUST_XFF=true


# -----------------------------------------------------------------------------
# 17. Gateway Runtime - Auth Cache
# -----------------------------------------------------------------------------

# [OPTIONAL] Header name for API key authentication
AUTH_APIKEY_HEADER=X-API-Key

# [OPTIONAL] Query parameter name for API key authentication
AUTH_APIKEY_PARAM=apikey

# [OPTIONAL] API key cache TTL in minutes
AUTH_APIKEY_CACHE_TTL=5

# [OPTIONAL] JWT validation cache TTL in minutes
AUTH_JWT_CACHE_TTL=60

# [OPTIONAL] Allow unauthenticated access to health endpoints
AUTH_ALLOW_ANON_HEALTH=true


# -----------------------------------------------------------------------------
# 18. Gateway Runtime - Access Logging
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable access logging
ACCESS_LOG_ENABLED=true

# [OPTIONAL] Include request/response headers in logs
ACCESS_LOG_HEADERS=false

# [OPTIONAL] Include request/response body in logs
ACCESS_LOG_BODY=false

# [OPTIONAL] Maximum body size to log in bytes
ACCESS_LOG_MAX_BODY=1024


# -----------------------------------------------------------------------------
# 19. Gateway Runtime - Routing
# -----------------------------------------------------------------------------

# [OPTIONAL] Reload route table on startup
ROUTING_RELOAD_ON_STARTUP=true

# [OPTIONAL] Enable route caching
ROUTING_CACHE_ENABLED=true


# -----------------------------------------------------------------------------
# 20. Gateway Runtime - Protocol Support (Phase 2+)
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable/disable protocol handlers
PROTOCOL_LLM=true
PROTOCOL_REST=true
PROTOCOL_SOAP=false
PROTOCOL_GRAPHQL=false
PROTOCOL_GRPC=false
PROTOCOL_WEBSOCKET=false
PROTOCOL_SSE=false
PROTOCOL_JSONRPC=false
PROTOCOL_ODATA=false

# [OPTIONAL] gRPC listen port
GRPC_PORT=9090


# -----------------------------------------------------------------------------
# 21. Gateway Runtime - Revocation Cache
# -----------------------------------------------------------------------------

# [OPTIONAL] Revocation list cache TTL in seconds
REVOCATION_CACHE_TTL=5


# -----------------------------------------------------------------------------
# 22. AI / LLM Provider Keys - used by gateway-runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] OpenAI API key (required if proxying OpenAI traffic)
OPENAI_API_KEY=

# [OPTIONAL] Anthropic API key (required if proxying Anthropic traffic)
ANTHROPIC_API_KEY=

# [OPTIONAL] DeepSeek API key (required if proxying DeepSeek traffic)
DEEPSEEK_API_KEY=


# -----------------------------------------------------------------------------
# 23. Service Mesh - used by gateway-runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable service mesh integration
SERVICE_MESH_ENABLED=false

# [OPTIONAL] Discovery type: static | docker | kubernetes
SERVICE_MESH_DISCOVERY_TYPE=static

# [OPTIONAL] Kubernetes namespace for service discovery
SERVICE_MESH_K8S_NAMESPACE=default

# [OPTIONAL] Default service port for discovered services
SERVICE_MESH_DEFAULT_PORT=8080

# [OPTIONAL] Kubernetes cluster domain
SERVICE_MESH_CLUSTER_DOMAIN=cluster.local


# -----------------------------------------------------------------------------
# 24. Event Gateway - used by gateway-runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] Event broker AMQP URL
EVENT_BROKER_URL=amqp://localhost:5672


# -----------------------------------------------------------------------------
# 25. Notification Channels - used by notification-service
# -----------------------------------------------------------------------------

# [OPTIONAL] Slack incoming webhook URL
SLACK_WEBHOOK_URL=

# [OPTIONAL] Microsoft Teams incoming webhook URL
TEAMS_WEBHOOK_URL=

# [OPTIONAL] Custom webhook notification endpoint
WEBHOOK_NOTIFICATION_URL=

# [OPTIONAL] Secret for signing webhook payloads
WEBHOOK_NOTIFICATION_SECRET=


# -----------------------------------------------------------------------------
# 26. Analytics - used by analytics-service
# -----------------------------------------------------------------------------

# [OPTIONAL] Number of days to retain audit log entries
AUDIT_RETENTION_DAYS=90
